{
  "compilerOptions": {
    "target": "es2020",
    "lib": ["es2020"],
    "module": "es2022",
    "declaration": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "allowJs": true,
    "rootDir": "src",
    "outDir": "lib-esm",
    "strict": true
  },
  "include": ["src/index.esm.ts"]
}